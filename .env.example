# ─── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_JWT_SECRET=              # Required in production for API route auth

# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://condorsalud.com
# NEXT_PUBLIC_DEMO_MODE=true
NODE_ENV=development
LOG_LEVEL=debug

# ─── Session / Security ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_ENCRYPTION_KEY=           # 64-char hex string, required in production

# ─── Google OAuth ──────────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Google Maps ───────────────────────────────────────────────
# GOOGLE_MAPS_API_KEY=              # Server-side (for geolocation proxy)
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=      # Client-side (for static maps)

# ─── Sentry ───────────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=condor-salud
# SENTRY_PROJECT=condor-salud

# ─── PostHog (Analytics) ──────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Upstash Redis (Rate Limiting) ────────────────────────────
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=

# ─── Anthropic (Claude AI for Cora chatbot) ───────────────────
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Twilio (WhatsApp notifications) ──────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=

# ─── Daily.co (Video / Telemedicine) ──────────────────────────
# DAILY_API_KEY=

# ─── MercadoPago (Payments) ───────────────────────────────────
# MP_ACCESS_TOKEN=
# NEXT_PUBLIC_MP_PUBLIC_KEY=

# ─── Resend (Transactional Email) ─────────────────────────────
# RESEND_API_KEY=

# ─── SendGrid (Transactional Email — v3) ──────────────────────
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=no-reply@condorsalud.com
# SENDGRID_FROM_NAME=Cóndor Salud
# SG_TPL_BOOKING_CONFIRMATION=
# SG_TPL_BOOKING_REMINDER=
# SG_TPL_BOOKING_CANCELLED=
# SG_TPL_BOOKING_CONFIRMED=
# SG_TPL_WELCOME_PATIENT=
# SG_TPL_WELCOME_DOCTOR=
# SG_TPL_RESET_PASSWORD=
# SG_TPL_NEW_REVIEW=

# ─── Firebase (Firestore + Storage — v3) ──────────────────────
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_STORAGE_BUCKET=

# ─── JWT (Patient/Doctor auth — v3) ───────────────────────────
# JWT_SECRET=                       # Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ─── Admin panel (v3) ─────────────────────────────────────────
# ADMIN_EMAIL=admin@condorsalud.com
# ADMIN_PASSWORD_HASH=              # Generate with: node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"

# ─── MercadoPago Webhook (v3) ─────────────────────────────────
# MP_WEBHOOK_SECRET=

# ─── Rides (Uber — v0.17.0) ───────────────────────────────────
# UBER_CLIENT_ID=                   # Optional — for Uber branding
# UBER_SERVER_TOKEN=                # Optional — for fare estimates
# REMISES_WHATSAPP_NUMBER=5491100000000

# ─── Google Calendar (Doctor agenda sync) ─────────────────────
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=https://api.condorsalud.com.ar/auth/google/callback

# ─── MercadoPago Subscription Plan IDs ────────────────────────
# MP_PLAN_ID_PROFESIONAL_MONTHLY=
# MP_PLAN_ID_PROFESIONAL_ANUAL=
# MP_PLAN_ID_PREMIUM_MONTHLY=
# MP_PLAN_ID_PREMIUM_ANUAL=

# ─── Web Push Notifications (VAPID) ───────────────────────────
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:soporte@condorsalud.com

# ─── Push Notifications (Expo — mobile future) ───────────────
# EXPO_ACCESS_TOKEN=

# ─── Cron Jobs (Vercel Cron) ──────────────────────────────────
# CRON_SECRET=                      # Auth header for /api/cron/* routes

# ─── WhatsApp Business API (reminders) ────────────────────────
# WHATSAPP_BUSINESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# ─── Demo Mode ────────────────────────────────────────────────
# DEMO_ADMIN_PASSWORD=change_this_demo_password

# ─── Scraper ──────────────────────────────────────────────────
# SCRAPER_TIMEOUT_MS=8000
# SCRAPER_USER_AGENT=CondorSalud/3.0 (+https://condorsalud.com.ar)

# ─── Nubix Cloud (RIS/PACS imaging) ───────────────────────────
# NUBIX_API_URL=
# NUBIX_API_KEY=
# NUBIX_TENANT_ID=

# ─── DCM4CHEE DICOM Archive ───────────────────────────────────
# DCM4CHEE_BASE_URL=https://pacs.example.com/dcm4chee-arc
# DCM4CHEE_AET=DCM4CHEE
# DCM4CHEE_USERNAME=
# DCM4CHEE_PASSWORD=
# DCM4CHEE_SECURE=true

# ─── PAMI API (when available) ────────────────────────────────
# PAMI_API_URL=
# PAMI_API_TOKEN=

# ─── AFIP WSFEV1 (Electronic invoicing) ───────────────────────
# AFIP_CERT_PATH=
# AFIP_KEY_PATH=
# AFIP_CUIT=

# ─── Swiss Medical ────────────────────────────────────────────
# SWISS_MEDICAL_CLIENT_ID=
# SWISS_MEDICAL_CLIENT_SECRET=
