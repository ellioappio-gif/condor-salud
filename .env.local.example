# =============================================================================
# Cóndor Salud — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# ─── Required for Launch (Tier 1) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://condorsalud.com.ar

# Sentry — Error Tracking (free tier: 5K errors/mo)
# Create project at https://sentry.io → Settings → Projects → DSN
SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/1234567
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/1234567
SENTRY_AUTH_TOKEN=sntrys_your-auth-token
SENTRY_ORG=condor-salud
SENTRY_PROJECT=condor-salud

# ─── Google OAuth ─────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Anthropic (Cora AI chatbot) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Tier 2: Email (Resend) ──────────────────────────────────
# RESEND_API_KEY=re_your_api_key

# ─── Tier 2: Analytics (PostHog) ─────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Tier 3: AFIP Integration ────────────────────────────────
# AFIP_CERT_PATH=/path/to/cert.pem
# AFIP_KEY_PATH=/path/to/key.pem
# AFIP_CUIT=30-12345678-9

# ─── Tier 3: PAMI Integration ────────────────────────────────
# Register clinic at https://prestadores.pami.org.ar
# PAMI_PRESTADOR_USER=your-prestador-user
# PAMI_PRESTADOR_PASS=your-prestador-password
# PAMI_PRESTADOR_CUIT=20-12345678-9
# PAMI_BASE_URL=https://prestadores.pami.org.ar/api

# ─── Tier 3: SISA / PUCO (Coverage Verification) ─────────────
# Register at https://sisa.msal.gov.ar with institutional email
# SISA_USER=your-sisa-username
# SISA_PASSWORD=your-sisa-password
# SISA_BASE_URL=https://sisa.msal.gov.ar/sisa/services/rest

# ─── Tier 3: Swiss Medical ───────────────────────────────────
# SWISS_MEDICAL_CLIENT_ID=your-client-id
# SWISS_MEDICAL_CLIENT_SECRET=your-client-secret

# ─── Tier 3: WhatsApp (Twilio fallback) ──────────────────────
# TWILIO_ACCOUNT_SID=your-sid
# TWILIO_AUTH_TOKEN=your-token
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Tier 3: WhatsApp (360dialog – primary) ──────────────────
# Get your Partner ID from https://hub.360dialog.io → Partner Settings
NEXT_PUBLIC_DIALOG360_PARTNER_ID=your-partner-id

# ─── Tier 3: Video Calls (Daily.co) ──────────────────────────
# DAILY_API_KEY=your-daily-key

# ─── Tier 3: Payments (MercadoPago) ──────────────────────────
# MP_ACCESS_TOKEN=your-mp-access-token
# NEXT_PUBLIC_MP_PUBLIC_KEY=your-mp-public-key

# ─── Optional ────────────────────────────────────────────────
# NEXT_PUBLIC_DEMO_MODE=true
# LOG_LEVEL=info

# ─── Tier 4: New Features (Migration 013) ────────────────────
# QR_BASE_URL — Base URL for prescription QR verification links
# QR_BASE_URL=https://condorsalud.com

# CRON_SECRET — Shared secret for authenticated cron endpoints
# CRON_SECRET=your-random-32-char-string
