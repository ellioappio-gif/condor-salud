{
  // Tailwind CSS uses @tailwind directives — suppress unknown-at-rule warnings
  "css.lint.unknownAtRules": "ignore",

  // Disable built-in CSS validation — Tailwind IntelliSense handles it
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,

  // File associations — Tailwind for CSS, PostgreSQL for Supabase migrations
  "files.associations": {
    "*.css": "tailwindcss",
    "**/supabase/migrations/*.sql": "postgres",
    "**/supabase/*.sql": "postgres"
  },

  // PostgreSQL migrations — fully disable MSSQL extension for .sql files
  // This project uses Supabase (PostgreSQL) — NOT Microsoft SQL Server
  "mssql.intelliSense.enableIntelliSense": false,
  "mssql.intelliSense.enableSuggestions": false,
  "mssql.intelliSense.enableQuickInfo": false,
  "mssql.intelliSense.enableErrorChecking": false,
  "mssql.enableQueryHistoryCapture": false,
  "mssql.enableSqlAuthenticationProvider": false,
  "mssql.ignorePlatformWarning": true,

  // Force all SQL files into PostgreSQL language mode
  "[sql]": {
    "editor.defaultFormatter": null,
    "editor.quickSuggestions": {
      "other": false,
      "comments": false,
      "strings": false
    }
  },
  "[postgres]": {
    "editor.defaultFormatter": null
  },

  // Exclude supabase temp files
  "files.exclude": {
    "supabase/.temp": true
  },

  // Ensure the TS language server restarts cleanly
  "typescript.tsdk": "node_modules/typescript/lib"
}
