{
  // Tailwind CSS uses @tailwind directives — suppress unknown-at-rule warnings
  "css.lint.unknownAtRules": "ignore",

  // Disable built-in CSS validation — Tailwind IntelliSense handles it
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,

  // Treat .css as Tailwind so IntelliSense works correctly
  "files.associations": {
    "*.css": "tailwindcss"
  },

  // PostgreSQL migrations — disable MSSQL diagnostics for .sql files
  "mssql.intelliSense.enableIntelliSense": false,
  "[sql]": {
    "editor.defaultFormatter": null
  },

  // Exclude supabase SQL from MSSQL linting
  "files.exclude": {
    "supabase/.temp": true
  },

  // Ensure the TS language server restarts cleanly
  "typescript.tsdk": "node_modules/typescript/lib"
}
